# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.

# --- Google Gemini ---
GOOGLE_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_BUCKET=uploads

# --- Gemini model names (optional — defaults shown) ---
GEMINI_GENERATION_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash

# --- Server (optional) ---
CORS_ORIGIN=http://localhost:3000
SESSION_COOKIE_NAME=sid
